# Copy to .env and adjust. For local dev, Docker Postgres from repo root: docker compose up -d
# DATABASE_URL must match docker-compose.yml (user/password/db).

NODE_ENV=development
PORT=5001
API_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://jiffyjobs_user:jiffyjobs_password@localhost:5432/jiffyjobs_dev

JWT_SECRET=change_me_in_production
JWT_EXPIRE=7d
COOKIE_SECRET=change_me_cookie_secret

# Email (Resend) — optional for local API; leave empty or use a real key
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost
EMAIL_FROM_NAME=JiffyJobs

# Stripe — optional for local API without payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PLATFORM_FEE_PERCENTAGE=5.0
AUTO_RELEASE_HOURS=48
